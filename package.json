		"@oh-my-pi/pi-tui": "^14.9.0",
		"commander": "^13.0.0",
		"dotenv": "^17.4.2",
		"gray-matter": "^4.0.3",
		"smol-toml": "^1.6.0",
		"typebox": "^1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
