{
	"name": "memforest",
	"version": "0.1.0",
	"description": "Multi-tenant, agent-native memory substrate",
	"type": "module",
	"bin": {
		"memforest": "./dist/index.js"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "bun --bun vitest run",
